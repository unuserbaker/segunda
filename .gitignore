build/
**/build/

# Ignorar coverage de tests
coverage/
**/coverage/

# Ignorar directorios de caché
.cache/
**/.cache/

# Docker
*.local
docker-compose.override.yml

# VSCode settings (opcional)
.vscode/

# Sistema operativo
.DS_Store
Thumbs.db

